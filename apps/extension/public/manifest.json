{
    "manifest_version": 3,
    "name": "HTML to Markdown Converter",
    "version": "1.0.0",
    "description": "Convert the current webpage into customizable Markdown.",
    "action": {
        "default_popup": "popup.html",
        "default_title": "Convert to Markdown"
    },
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}